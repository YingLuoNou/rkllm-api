# OpenAI 兼容服务监听
OPENAI_API_HOST=0.0.0.0
OPENAI_API_PORT=8081

# OpenAI 兼容配置
OPENAI_MODEL_NAME=qwen2.5-3b-rk3588
OPENAI_API_KEY=EMPTY
OPENAI_MAX_INPUT_CHARS=12000
OPENAI_REQUEST_TIMEOUT_SEC=60

# RKLLM 本地 NPU 直连配置（非 ROS、非上游转发）
RKLLM_LIBRARY_PATH=../rkllm-ros2/lib/librkllmrt.so
RKLLM_MODEL_PATH=/data/llm/model/Qwen2.5-3B-w8a8.rkllm
RKLLM_MAX_NEW_TOKENS=512
RKLLM_MAX_CONTEXT_LEN=2048
RKLLM_TOP_K=1
RKLLM_TOP_P=0.95
RKLLM_TEMPERATURE=0.8
RKLLM_REPEAT_PENALTY=1.1
